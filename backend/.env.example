# Backend environment variables
# Copy this file to .env and fill in real values.

# Railway/Render MySQL connection string
# Example:
# mysql://user:password@host:3306/database
DATABASE_URL=

# Secret for signing JWT tokens (use a long random string)
JWT_SECRET=

# Optional token lifetime
# Example: 7d, 12h, 30m
JWT_EXPIRES_IN=7d

# Backend port (on hosting platforms it can be injected automatically)
PORT=5000

# Public URL of frontend app (used for CORS)
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
